{
  "name": "ap-prep-hub",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@sentry/react": "^10.49.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "firebase": "^10.14.1",
    "framer-motion": "^11.2.10",
    "katex": "^0.16.22",
    "lucide-react": "^0.395.0",
    "pdfjs-dist": "^5.4.394",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-katex": "^3.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.23.1",
    "react-scripts": "5.0.1",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "NODE_OPTIONS=--no-deprecation react-scripts start",
    "build": "NODE_OPTIONS=--no-deprecation REACT_APP_VERSION=$npm_package_version react-scripts build",
    "test": "NODE_OPTIONS=--no-deprecation react-scripts test",
    "eject": "react-scripts eject",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0"
  }
}
