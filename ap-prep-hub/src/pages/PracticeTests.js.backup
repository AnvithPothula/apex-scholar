  const generateQuestionBatch = async (subject, section, difficulty, numQuestions, startId, apiKey, apiUrl) => {
    let sectionInstructions = '';
    let subjectContext = '';
    
    // Add subject-specific context for better questions
    switch(subject) {
      case 'AP U.S. History':
      case 'AP US History':
        subjectContext = `Focus on periods: Colonial Era (1607-1754), Revolution (1754-1800), Early Republic (1800-1848), Civil War Era (1844-1877), Industrialization (1865-1898), Early 20th Century (1890-1945), Modern America (1945-1980). Include diverse perspectives and historical thinking skills.`;
        break;
      case 'AP World History':
      case 'AP World History: Modern':
        subjectContext = `Focus on periods: 1200-1450, 1450-1750, 1750-1900, 1900-present. Emphasize global processes, cross-cultural interactions, trade networks, and political systems.`;
        break;
      case 'AP European History':
        subjectContext = `Focus on periods: Renaissance, Reformation, Absolutism, Enlightenment, French Revolution, Industrial Revolution, 19th-century nationalism, WWI, interwar, WWII, Cold War.`;
        break;
      case 'AP Biology':
        subjectContext = `Focus on: Cell Biology, Genetics, Evolution, Ecology, Biochemistry. Include experimental design and data analysis with realistic biological scenarios.`;
        break;
      case 'AP Chemistry':
        subjectContext = `Focus on: Atomic structure, bonding, stoichiometry, kinetics, equilibrium, thermodynamics. Include laboratory scenarios and calculations.`;
        break;
      case 'AP Calculus AB':
      case 'AP Calculus BC':
        subjectContext = `Focus on: Limits, derivatives, integrals, applications. Include real-world contexts and graphical analysis.`;
        break;
      default:
        subjectContext = `Create authentic questions that reflect real AP exam standards for ${subject}.`;
    }
    
    // Simplified section instructions
    if (section === 'mcq') {
      sectionInstructions = `Create ${numQuestions} multiple choice questions with exactly 4 options (A, B, C, D). Each question must test analytical thinking and include realistic distractors. ${subjectContext}`;
    } else if (section === 'frq' || section === 'saq') {
      sectionInstructions = `Create ${numQuestions} free response questions with clear prompts and detailed rubrics. Include realistic scenarios and multiple parts. ${subjectContext}`;
    } else if (section === 'dbq') {
      sectionInstructions = `Create 1 Document-Based Question with 7 historical documents. Include real historical content with proper sourcing. ${subjectContext}`;
    } else if (section === 'leq') {
      sectionInstructions = `Create 1 Long Essay Question with 3 specific prompt options using real time periods. ${subjectContext}`;
    } else if (section === 'all-frq') {
      if (subject.includes('History')) {
        sectionInstructions = `Create exactly 5 questions: 3 Short Answer Questions with historical sources, 1 Document-Based Question with 7 documents, and 1 Long Essay Question with 3 prompts. Use real historical content. ${subjectContext}`;
      } else {
        sectionInstructions = `Create ${numQuestions} comprehensive free response questions appropriate for ${subject}. ${subjectContext}`;
      }
    } else {
      sectionInstructions = `Create ${numQuestions} questions for ${section} section of ${subject}. ${subjectContext}`;
    }

    const systemPrompt = `You are an expert AP test generator. Generate authentic AP ${subject} questions.

REQUIREMENTS:
- Generate exactly ${numQuestions} questions
- Start question IDs from ${startId}
- Difficulty: ${difficulty}
- Question type: ${section}
- Use real content, not placeholders
- Include proper rubrics for FRQ questions
- For MCQ: exactly 4 options with clear correct answer
- For DBQ: exactly 7 historical documents with real content
- For LEQ: exactly 3 specific prompts

INSTRUCTIONS: ${sectionInstructions}

Return ONLY a valid JSON array. No explanatory text or markdown formatting.

Example format:
[
  {
    "id": ${startId},
    "type": "${section === 'mcq' ? 'mcq' : 'frq'}",
    "question": "Actual question text...",
    ${section === 'mcq' ? `"options": ["A) ...", "B) ...", "C) ...", "D) ..."],
    "correctAnswer": 0,
    "explanation": "..."` : `"parts": ["a) ...", "b) ...", "c) ..."],
    "sampleAnswer": "...",
    "rubric": {"totalPoints": 6, "scoringGuidelines": "..."}`},
    "topic": "...",
    "difficulty": "${difficulty}",
    "estimatedTime": 90
  }
]`;

    try {
      const response = await fetch(apiUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{
            role: "user",
            parts: [{ text: systemPrompt }]
          }],
          generationConfig: {
            temperature: 0.7,
            topK: 40,
            topP: 0.95,
            maxOutputTokens: 4000,
            candidateCount: 1
          }
        })
      });

      if (!response.ok) {
        throw new Error(`API request failed: ${response.status} ${response.statusText}`);
      }

      const result = await response.json();
      
      if (!result.candidates || !result.candidates[0] || !result.candidates[0].content) {
        throw new Error('Invalid API response structure');
      }

      const generatedText = result.candidates[0].content.parts[0].text;
      
      console.log('Raw AI response:', generatedText);
      
      // Enhanced cleaning and validation
      let cleanedText = generatedText.replace(/```json\n?|\n?```/g, '').trim();
      
      // Check if response was truncated
      if (!cleanedText.endsWith(']') && !cleanedText.endsWith('}')) {
        console.warn('Response appears to be truncated');
        throw new Error('Response was truncated by API');
      }
      
      // Try to fix common JSON issues
      if (!cleanedText.startsWith('[') && !cleanedText.startsWith('{')) {
        const arrayStart = cleanedText.indexOf('[');
        if (arrayStart !== -1) {
          cleanedText = cleanedText.substring(arrayStart);
        } else {
          throw new Error('No valid JSON array found in response');
        }
      }
      
      // Additional cleanup
      cleanedText = cleanedText
        .replace(/```[\w]*\n?/g, '')
        .replace(/\n\n+/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
      
      console.log('Cleaned text for parsing:', cleanedText.substring(0, 200) + '...');
      
      let questions;
      try {
        questions = JSON.parse(cleanedText);
      } catch (parseError) {
        console.error('JSON parsing failed:', parseError);
        console.error('Text that failed to parse:', cleanedText.substring(0, 500));
        throw new Error(`Failed to parse AI response: ${parseError.message}`);
      }
      
      if (!Array.isArray(questions) || questions.length === 0) {
        console.error('Invalid questions array:', questions);
        throw new Error('No valid questions received from AI');
      }

      // Basic validation
      const validQuestions = questions.filter(q => {
        if (!q.question || q.question.length < 20) return false;
        if (q.type === 'mcq' && (!q.options || q.options.length !== 4)) return false;
        return true;
      });

      if (validQuestions.length === 0) {
        throw new Error('No valid questions passed validation');
      }

      console.log('Successfully parsed and validated questions:', validQuestions.length);
      return validQuestions;
      
    } catch (error) {
      console.error('Error in generateQuestionBatch:', error);
      throw error;
    }

    return result;
  };

  const handleNextQuestion = () => {
    if (currentQuestionIndex < questions.length - 1) {
