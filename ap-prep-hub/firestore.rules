rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User documents - only accessible by the owner
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // User's test history
      match /testHistory/{testId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User's flashcards
      match /flashcards/{flashcardId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User's progress data
      match /progress/{progressId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User's Schoology tokens - extra sensitive
      match /schoologyTokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User's settings and preferences
      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User's scheduler tasks
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User's scheduler preferences
      match /schedulerPreferences/{prefId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User's third-party integrations (Schoology, etc.)
      match /integrations/{integrationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User's sync history (Schoology assignment sync tracking)
      match /syncHistory/{syncId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Conversations at root level - accessible by owner
    match /conversations/{conversationId} {
      allow read, write: if request.auth != null &&
                           request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
                      request.auth.uid == request.resource.data.userId;

      // Messages within conversations — scoped to conversation owner
      match /messages/{messageId} {
        allow read, write: if request.auth != null &&
                             request.auth.uid == get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId;
      }

      // MCQ responses within conversations — scoped to conversation owner
      match /mcqResponses/{responseId} {
        allow read, write: if request.auth != null &&
                             request.auth.uid == get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId;
      }
    }

    // Flashcard decks at root level - owner can read/write, anyone authenticated can read public decks
    match /flashcardDecks/{deckId} {
      // Owner can always read/write their own decks
      allow read, write: if request.auth != null &&
                           request.auth.uid == resource.data.userId;
      // Any authenticated user can read a public deck
      allow read: if request.auth != null &&
                    resource.data.isPublic == true;
      allow create: if request.auth != null &&
                      request.auth.uid == request.resource.data.userId;
    }

    // Solver history at root level - accessible by owner
    match /solverHistory/{historyId} {
      allow read, write: if request.auth != null &&
                           request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
                      request.auth.uid == request.resource.data.userId;
    }

    // Schoology tokens at root level - accessible by owner
    match /schoologyTokens/{tokenId} {
      allow read, write: if request.auth != null &&
                           request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
                      request.auth.uid == request.resource.data.userId;
    }

    // User progress at root level - accessible by owner
    match /userProgress/{progressId} {
      allow read, write: if request.auth != null &&
                           request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
                      request.auth.uid == request.resource.data.userId;
    }

    // Practice tests at root level - accessible by owner
    match /practiceTests/{testId} {
      allow read, write: if request.auth != null &&
                           request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
                      request.auth.uid == request.resource.data.userId;
    }

    // Test progress at root level - accessible by owner
    match /testProgress/{progressId} {
      allow read, write: if request.auth != null &&
                           request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
                      request.auth.uid == request.resource.data.userId;
    }

    // Study sessions at root level - accessible by owner
    match /studySessions/{sessionId} {
      allow read, write: if request.auth != null &&
                           request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
                      request.auth.uid == request.resource.data.userId;
    }

    // Diagnostic results at root level - accessible by owner
    match /diagnosticResults/{resultId} {
      allow read, write: if request.auth != null &&
                           request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
                      request.auth.uid == request.resource.data.userId;
    }

    // User achievements at root level - accessible by owner
    match /userAchievements/{achievementId} {
      allow read, write: if request.auth != null &&
                           request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
                      request.auth.uid == request.resource.data.userId;
    }

    // Public read-only data (for future use - e.g., shared study resources)
    match /publicData/{document=**} {
      allow read: if true;
      allow write: if false; // Only admins can write (implement admin check if needed)
    }

    // Admin list — add admin UIDs as documents in this collection
    // e.g., /admins/{uid} with any field
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Reviews - any authenticated user can create; admins can read/delete
    match /reviews/{reviewId} {
      allow create: if request.auth != null &&
                      request.auth.uid == request.resource.data.userId;
      allow read, delete: if isAdmin();
    }

    // Admin collection - only admins can read, no one can write via client
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
