# Firebase Configuration (required)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_DATABASE_URL=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# ---------------------------------------------------------------------------
# Gemini AI fallback (used when Puter is unavailable)
#
# PRODUCTION: do NOT set REACT_APP_GEMINI_API_KEY* here. Those are inlined into
# the JS bundle and would expose the keys. Instead set the SERVER-SIDE keys in
# Netlify env (GEMINI_API_KEY, GEMINI_API_KEY_2 … _11) — the ai-proxy Netlify
# function uses them and never ships them to the browser. The client calls the
# proxy at /.netlify/functions/ai-proxy automatically.
#
# LOCAL DEV: the REACT_APP_GEMINI_API_KEY* below let `npm start` hit Gemini
# directly without running `netlify dev`. Leave them blank in any committed/
# deployed env. (To force the proxy locally, set REACT_APP_USE_AI_PROXY=true and
# run `netlify dev`.)
# ---------------------------------------------------------------------------
REACT_APP_GEMINI_API_KEY=
REACT_APP_GEMINI_API_KEY_2=
REACT_APP_GEMINI_API_KEY_3=
REACT_APP_GEMINI_API_KEY_4=
REACT_APP_GEMINI_API_KEY_5=
REACT_APP_GEMINI_API_KEY_6=
REACT_APP_GEMINI_API_KEY_7=
REACT_APP_GEMINI_API_KEY_8=
REACT_APP_GEMINI_API_KEY_9=
REACT_APP_GEMINI_API_KEY_10=
REACT_APP_GEMINI_API_KEY_11=

# AI proxy transport (optional overrides)
#   REACT_APP_USE_AI_PROXY: "true" forces the proxy, "false" forces direct keys.
#     Default = proxy in production; direct in dev when client keys are present.
#   REACT_APP_AI_PROXY_URL: override the proxy endpoint (default same-origin
#     /.netlify/functions/ai-proxy).
#   REACT_APP_AI_PROXY_APP_TOKEN: only if the server sets AI_PROXY_APP_TOKEN.
#     NOTE: this is public (bundle-inlined) — a weak bot deterrent, not a secret.
REACT_APP_USE_AI_PROXY=
REACT_APP_AI_PROXY_URL=
REACT_APP_AI_PROXY_APP_TOKEN=

# --- Server-side only (set these in Netlify env, NOT with a REACT_APP_ prefix) ---
# GEMINI_API_KEY, GEMINI_API_KEY_2 … GEMINI_API_KEY_11   (used by ai-proxy)
# ALLOWED_ORIGINS=https://your-domain.com                (CORS allowlist)
# AI_PROXY_APP_TOKEN=                                     (optional app token)
#
# Optional: tamper-proof per-user AI quotas (Codex P1-1). Until FIREBASE_SERVICE_ACCOUNT
# is set, the proxy works exactly as before (no auth, no server quota).
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}  (full JSON, one line)
# AI_PROXY_REQUIRE_AUTH=false      (true = reject requests without a Firebase ID token; keep false to allow guests)
# AI_PROXY_5H_LIMIT=120            (server backstop: AI calls per user per 5h)
# AI_PROXY_WEEK_LIMIT=600          (server backstop: AI calls per user per week)

# EmailJS (for feedback form)
REACT_APP_EMAILJS_SERVICE_ID=
REACT_APP_EMAILJS_TEMPLATE_ID=
REACT_APP_EMAILJS_PUBLIC_KEY=

# Sentry error monitoring (production only; leave blank to disable)
REACT_APP_SENTRY_DSN=
REACT_APP_SENTRY_ENV=production

# App version (used as Sentry release tag; set at build time)
REACT_APP_VERSION=
