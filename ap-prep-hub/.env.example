# Apex Scholar - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ==============================================================================
# Google Gemini API Keys
# ==============================================================================
# Get your API keys from: https://makersuite.google.com/app/apikey
# You can use multiple keys for rotation to handle rate limits

REACT_APP_GEMINI_API_KEY=your_primary_gemini_api_key_here
REACT_APP_GEMINI_API_KEY_2=your_secondary_gemini_api_key_here
REACT_APP_GEMINI_API_KEY_3=your_third_gemini_api_key_here
REACT_APP_GEMINI_API_KEY_4=your_fourth_gemini_api_key_here
REACT_APP_GEMINI_API_KEY_5=your_fifth_gemini_api_key_here
REACT_APP_GEMINI_API_KEY_6=your_sixth_gemini_api_key_here
REACT_APP_GEMINI_API_KEY_7=your_seventh_gemini_api_key_here
REACT_APP_GEMINI_API_KEY_8=your_eighth_gemini_api_key_here
REACT_APP_GEMINI_API_KEY_9=your_ninth_gemini_api_key_here
REACT_APP_GEMINI_API_KEY_10=your_tenth_gemini_api_key_here
REACT_APP_GEMINI_API_KEY_11=your_eleventh_gemini_api_key_here

# Optional: Specify preferred Gemini model (leave empty for default)
REACT_APP_GEMINI_MODEL=

# Optional: Enable AI debug logging
REACT_APP_AI_DEBUG=false

# ==============================================================================
# Firebase Configuration
# ==============================================================================
# Get these from Firebase Console: https://console.firebase.google.com/
# Project Settings > General > Your apps > SDK setup and configuration

REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
REACT_APP_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id
REACT_APP_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ==============================================================================
# EmailJS Configuration (for feedback form)
# ==============================================================================
# Get your credentials from: https://www.emailjs.com/
# Dashboard > Email Services > Add New Service

REACT_APP_EMAILJS_SERVICE_ID=your_emailjs_service_id
REACT_APP_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
REACT_APP_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# ==============================================================================
# Optional: Schoology API (for LMS integration)
# ==============================================================================
# Only needed if using Schoology integration features

# REACT_APP_SCHOOLOGY_CONSUMER_KEY=your_schoology_consumer_key
# REACT_APP_SCHOOLOGY_CONSUMER_SECRET=your_schoology_consumer_secret
