# Force correct Content-Type for SEO files so search engines parse them
# correctly. Without this, Netlify can serve them as text/html in some
# cases — which makes Bing/Google reject the sitemap as "HTML, not XML".

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

/llms-full.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

# IndexNow ownership-verification key file
/*.txt
  Content-Type: text/plain; charset=utf-8

# CRA emits hashed asset filenames (main.<hash>.js, main.<hash>.css, etc.)
# under /static/, so the contents at any given URL are immutable. Cache them
# aggressively. `immutable` tells browsers not to revalidate even on reload.
/static/*
  Cache-Control: public, max-age=31536000, immutable

# Logo + brand assets — long cache, but not "immutable" since the URLs
# aren't content-hashed and we may swap them in place.
/Apex_Scholar_Logo*.png
  Cache-Control: public, max-age=2592000

/Apex_Scholar_Logo*.webp
  Cache-Control: public, max-age=2592000

/favicon-*.png
  Cache-Control: public, max-age=2592000

/favicon.ico
  Cache-Control: public, max-age=2592000
